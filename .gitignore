# Explicitly ignore doc directory
/doc/

# Ignore anything else as required by user, but since the user said "exclude doc and other file expect readme and .github"
# Let's do the exclude all strategy correctly

# Ignore all files
*

# Allow directories to be traversed
!*/

# Now, allow everything inside .github directory
!/.github/
!/.github/**

# Allow README files in root
!/README.md
!/readme.md
!/Readme.md

# Allow .gitignore itself
!/.gitignore

# Allow everything inside services/ directory
!/services/
!/services/**
