# ============================================================
# GEO Platform — Environment Variables
# Copy to .env and fill in your keys
# ============================================================

# --- App Settings ---
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=INFO

# --- FastAPI ---
API_HOST=0.0.0.0
API_PORT=8000

# --- HMAC Auth (shared secret with Node.js) ---
HMAC_SECRET_KEY=your-hmac-secret-here

# --- Groq (Internal LLM — dual keys for rate limit) ---
GROQ_API_KEY_1=gsk_your_key_1
GROQ_API_KEY_2=gsk_your_key_2

# --- Fireworks AI (Fallback provider) ---
FIREWORKS_API_KEY=your-fireworks-key

# --- Mistral (Fallback provider) ---
MISTRAL_API_KEY=your-mistral-key

# --- Google (Gemini Vision + emergency fallback) ---
GOOGLE_API_KEY=your-google-api-key

# --- Customer LLM Providers (for Agent 3 testing) ---
OPENAI_API_KEY=your-openai-key
XAI_API_KEY=your-xai-key
ANTHROPIC_API_KEY=your-anthropic-key
PERPLEXITY_API_KEY=your-perplexity-key

# --- Search APIs ---
TAVILY_API_KEY=tvly-your-tavily-key
GOOGLE_CSE_API_KEY=your-google-cse-key
GOOGLE_CSE_ENGINE_ID=your-search-engine-id

# --- LangFuse Observability ---
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key
LANGFUSE_SECRET_KEY=your-langfuse-secret-key
LANGFUSE_HOST=https://cloud.langfuse.com
